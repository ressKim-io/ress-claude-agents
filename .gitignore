# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
*.log

# Environment
.env
.env.local
.env.*.local

# Backup files
*.backup
*.bak

# Claude local settings (user-specific)
.claude/settings.local.json

# Temporary working files (session safety net for in-progress work)
tmp/

# Auto-generated tool caches
# .agents/는 P7까지 deprecate 예정 (assets/skills/ SSOT로 이동), 그동안 ignore.
# .codex/는 P4 adapter SSoT view → commit 대상 (0002 plan §86-89, decision log P4-C).
.agents/

# .claude/skills/<cat>/<n>/SKILL.md (디렉토리 형식)는 P4 adapter --tool=claude 산출물이지만
# P7까지는 단일 파일 형식(.claude/skills/<cat>/<n>.md)이 SSOT view. dual-tree 충돌 회피로
# SKILL.md 디렉토리는 commit 안 함 (decision log P4-D, plan §86-89). codex/cursor view는 commit.
.claude/skills/*/*/SKILL.md
.claude/skills/*/*/resources/
.claude/skills/*/*/scripts/

# control-plane init 산출물은 self-bootstrap 결과 — 메타 레포 fork/clone 시 각자 init 재실행이
# 의도된 흐름. install 받은 프로젝트에서는 사용자 가시성 위해 commit 가능하지만, SSOT 메타
# 레포에선 충돌 회피로 ignore (P6.5 baseline 진입 시 hook 설치 후 발견된 결정).
.claude-agents.yml
project-profile.yml
